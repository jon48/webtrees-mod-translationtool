{
	"name" : "jon48/webtrees-mod-translationtool",
	"description" : "MyArtJaub Translations Module for webtrees",
	"type" : "webtrees-module",
	"keywords" : [
		"webtrees",
		"genealogy",
		"internationalisation",
		"webtrees-module"
	],
	"homepage" : "https://github.com/jon48/webtrees-mod-translationtool",
	"license" : "GPL-3.0-or-later",
	"authors" : [{
			"name" : "Jonathan Jaubart",
			"email" : "dev@jaubart.com",
			"homepage" : "http://www.jaubart.com",
			"role" : "Developer"
		}
	],
	"support" : {
		"issues" : "https://github.com/jon48/webtrees-mod-translationtool/issues"
	},
	"config": {
		"platform" : {
			"php" : "7.4"
		},
		"allow-plugins": {
			"composer/package-versions-deprecated": true,
			"bamarni/composer-bin-plugin": true
		}
	},
	"autoload" : {
		"psr-4" : {
			"MyArtJaub\\Webtrees\\Module\\TranslationTool\\" : "app"
		}
	},
	"require" : {
		"composer/composer" : "^1.0|^2.0",
		"fisharebest/localization" : "^1.0",
		"gettext/gettext" : "^5.0",
		"gettext/php-scanner" : "^2.0",
		"fisharebest/webtrees" : "~2.1.26",
		"jon48/webtrees-lib" : "dev-main-2.1 as dev-main",
		"league/commonmark": "2.8.2 as 2.8.0"
	},
	"require-dev" : {
		"bamarni/composer-bin-plugin": "^1.8"
	},
	"scripts" : {
		"webtrees-mod-translationtool:phpcs" : "./vendor-bin/php-cs/vendor/bin/phpcs -s --exclude=Generic.Files.LineEndings",
		"webtrees-mod-translationtool:phpcbf" : "./vendor-bin/php-cs/vendor/bin/phpcbf --exclude=Generic.Files.LineEndings",
		"webtrees-mod-translationtool:phpstan" : "./vendor-bin/phpstan/vendor/bin/phpstan analyze --no-progress",
		"webtrees-mod-translationtool:psalm" : "psalm",
		"webtrees-mod-translationtool:sonar" : "sonar-scanner"
	},
	"extra" : {
		"installer-name" : "myartjaub_translationtool",
		"bamarni-bin": {
            "bin-links": false,
			"forward-command": true
        }
	}
}